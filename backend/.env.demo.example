# =============================================
#  竞赛演示模式环境变量模板
#  复制此文件为 .env.demo 并填入真实密钥
# =============================================
JWT_SECRET_KEY=replace-with-any-long-random-string
APP_MODE=demo

# DeepSeek LLM (选填，不填则使用启发式评分)
OPENAI_API_KEY=sk-your-deepseek-api-key
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat
